{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": "Debug"
  },
  "Simulator": {
    "BaseUrl": "http://localhost:5000",
    "ConcurrentUsers": 1,
    "OrdersPerUser": 3,
    "MaxProductsPerOrder": 2,
    "DelayMinMs": 300,
    "DelayMaxMs": 1000,
    "RampUpTimeSeconds": 30
  },
  "Redis": {
    "Enabled": false
  }
}
