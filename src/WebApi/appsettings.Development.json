{
  "ConnectionString": "Server=localhost;Port=5432;Database=Clean-DB;User Id=postgres;Password=Abc@1234;Timeout=300;CommandTimeout = 300;Pooling=true;Minimum Pool Size=0;Maximum Pool Size=20;",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Key": "super-duper-secret-value-that-should-be-in-user-secrets",
    "Issuer": "developers",
    "Audience": "developers",
    "ExpirationInMinutes": 600
  }
}
