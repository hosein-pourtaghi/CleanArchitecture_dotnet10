{
  //"ConnectionString": "Server=localhost;Port=5432;Database=Clean-DB_P;User Id=postgres;Password=Abc@1234;Timeout=300;CommandTimeout = 300;Pooling=true;Minimum Pool Size=0;Maximum Pool Size=20;",
  "ConnectionString": "Server=localhost;Database=Clean_DB_SQL;User Id=sa;Password=Abc@1234;Integrated Security=false;MultipleActiveResultSets=true;TrustServerCertificate=True",
  //"ConnectionString": "Server=192.168.1.5,1433;Database=Clean_DB_SQL;Integrated Security=false;User Id=sa;Password=Abc@1234;MultipleActiveResultSets=true;TrustServerCertificate=True",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Sinks.MSSqlServer"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning", // Reduce noise from EF Core and ASP.NET internals
        "Microsoft.EntityFrameworkCore": "Warning", // Reduce noise from EF Core and ASP.NET internals
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information" // Keep startup logs
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          // Use the connection string defined above
          "connectionString": "Data Source=.;Initial Catalog=Clean_DB_SQL;Integrated Security=false;User Id=sa;Password=Abc@1234;MultipleActiveResultSets=true;TrustServerCertificate=True",
          "tableName": "AppLogs",
          "autoCreateSqlTable": true,
          "restrictedToMinimumLevel": "Warning",
          // Optional: Define which columns to store (Standard Serilog columns)
          "columnOptionsSection": {
            "addStandardColumns": [ "LogEvent", "MessageTemplate", "Level", "TimeStamp", "Exception" ],
            "removeStandardColumns": [ "Properties" ]
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Admin": {
    "Email": "a@b.c",
    "Password": "Aa@11221122",
    "Role": "Admin"
  },
  "LoggingSettings": {
    "EnableApiLogging": true,
    "EnableExceptionLogging": true,
    "EnablePerformanceLogging": true,
    "ShowDetailsInProduction": false,
    "BatchSize": 100,
    "BatchIntervalMs": 1000,
    "MaxQueueSize": 10000,
    "ExcludedPaths": [ "/health", "/metrics", "/favicon.ico" ],
    "EnableSensitiveDataLogging": false,
    "SensitiveHeaders": [ "Authorization", "Cookie", "X-Api-Key" ]
  },
  "ConnectionStrings": {
    "LoggingConnection": "Server=.;Database=MyApp_Logging;Trusted_Connection=True;TrustServerCertificate=True;"
  }, 

  "Jwt": {
    "Key": "super-duper-secret-value-that-should-be-in-user-secrets",
    "Issuer": "developers",
    "Audience": "developers",
    "ExpirationInMinutes": 600
  }
}
